# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# Admin credentials for the login tests.
# For the public demo (automationintesting.online) these are:
ADMIN_USER=admin
ADMIN_PASSWORD=password

# Optional: which environment to target. Defaults to "production".
# Valid values: production | local  (see environments.ts)
# ENV=production
